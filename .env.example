# Frontend
NEXT_PUBLIC_API_BASE_URL=https://your-backend.example.com
FRONTEND_BASE_URL=https://your-frontend.example.com
BRAND_LOGO_URL=https://your-frontend.example.com/assets/branding/lifewood-logo.svg

# Backend
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
ALLOWED_HOSTS=your-backend.example.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:3000

# Email delivery
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_SERVICE_API_KEY=
DEFAULT_FROM_EMAIL=Lifewood HR <hr@your-domain.com>
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-smtp-or-provider-secret
EMAIL_USE_TLS=true

# File uploads / cloud storage
STORAGE_BUCKET_URL=https://your-storage-bucket.example.com
